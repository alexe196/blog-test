# Composer
/vendor/

# Local config / env
.env
.env.local

# Smarty compiled templates and cache
/var/cache/*
/var/compile/*
!/var/cache/.gitkeep
!/var/compile/.gitkeep

# Logs
*.log
/logs/
/var/log/

