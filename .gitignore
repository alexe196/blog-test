.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
/tmp/
/temp/
/.cache/

# Local database dumps
*.sql.gz
*.dump
*.backup
*.bak

# Docker local override
docker-compose.override.yml

# Node / SCSS tools if we add SCSS later
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*